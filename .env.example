# Build Configuration (Required for deployment)
GENERATE_SOURCEMAP=false
CI=false
DISABLE_ESLINT_PLUGIN=true
SKIP_PREFLIGHT_CHECK=true

# Portfolio Configuration (Optional - has defaults)
REACT_APP_PORTFOLIO_NAME="Your Name Portfolio"
REACT_APP_PORTFOLIO_URL="https://yoursite.vercel.app"

# GitHub Configuration (Optional - used for automatic project sync)
REACT_APP_GITHUB_USERNAME=yourusername
REACT_APP_GITHUB_API_URL=https://api.github.com

# Contact Information (Optional - can be hardcoded in components)
REACT_APP_EMAIL=your.email@gmail.com
REACT_APP_PHONE="+91 1234567890"
REACT_APP_LOCATION="Your City, State, Country"

# Social Media Links (Optional - can be hardcoded in components)
REACT_APP_GITHUB_URL=https://github.com/yourusername
REACT_APP_LINKEDIN_URL=https://www.linkedin.com/in/yourprofile/
REACT_APP_LEETCODE_URL=https://leetcode.com/u/yourusername/

# Feature Flags (Optional - controls automatic features)
REACT_APP_AUTO_CERTIFICATE_DETECTION=true
REACT_APP_AUTO_GITHUB_SYNC=true

# API Keys (None required for basic functionality)
# REACT_APP_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX (if you want analytics)
# REACT_APP_EMAILJS_SERVICE_ID=your_service_id (if you want contact form emails)
# REACT_APP_EMAILJS_TEMPLATE_ID=your_template_id
# REACT_APP_EMAILJS_PUBLIC_KEY=your_public_key